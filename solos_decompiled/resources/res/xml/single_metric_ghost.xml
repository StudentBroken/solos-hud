<?xml version="1.0" encoding="utf-8"?>
<page
    name="single_metric_ghost"
    align="top"
    version="2">
    <include source="_header"/>
    <box
        width="428"
        height="159"
        align="left"
        marginTop="1"
        marginBottom="5">
        <box
            width="123"
            height="130"
            align="top"
            marginTop="18">
            <image
                name="metric_image"
                source="cadence_img2"
                width="90"
                height="90"
                color="default_font"
                marginLeft="28"
                marginRight="5"/>
            <textarea
                width="100"
                height="32"
                size="15"
