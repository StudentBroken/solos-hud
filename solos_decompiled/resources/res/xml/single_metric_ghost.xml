                content="--------------"
                bold="false"
                marginTop="8"
                text_align="center_horizontal"
                marginLeft="23"/>
        </box>
        <box
            width="298"
            height="159"
            align="top">
            <box
                width="298"
                height="94"
                align="right"
                paddingRight="16">
                <textarea
                    width="24"
                    height="70"
                    size="19"
                    name="unit"
                    content="---"
                    marginLeft="8"
                    paddingTop="24"
                    iosVerticalAdjust="20"/>
                <textarea
                    width="256"
                    height="94"
                    size="80"
                    name="value"
                    content="-------"
                    bold="true"
                    text_align="right"
                    colour="@color/single_unit_text"
                    iosWidthAdjust="-6"/>
            </box>
            <box
                width="298"
                height="65"
                align="right"
                paddingRight="16">
                <textarea
                    width="24"
                    height="45"
                    size="14"
                    name="unit"
                    content="---"
                    marginLeft="8"
                    paddingTop="20"
                    iosVerticalAdjust="20"/>
                <textarea
                    width="216"
                    height="65"
                    size="54"
                    name="ghostvalue"
                    content="-------"
                    bold="true"
                    text_align="right"/>
            </box>
        </box>
    </box>
    <include source="_ghost_bar"/>
</page>
