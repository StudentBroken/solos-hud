<?xml version="1.0" encoding="utf-8"?>
<page
    name="ride_stats"
    align="top"
    version="2">
    <include source="_header"/>
    <box
        name="metric1"
        width="428"
        height="80"
        align="left"
        paddingLeft="54"
        paddingRight="54"
        marginTop="8">
        <image
            source="stats_icon"
            width="60"
            height="60"
            color="default_font"
            marginTop="4"/>
        <textarea
            size="54"
            name="timeElapsedValue"
            width="230"
            height="64"
            content="00:00:00"
            bold="true"
            text_align="right"
            colour="@color/single_unit_text"
            marginRight="4"/>
    </box>
    <rectangle
        width="356"
        height="1"
        marginLeft="36"
        marginRight="36"
        marginTop="3"
        marginBottom="3"
        color="@color/white"/>
    <box
        width="428"
        height="80"
        align="left"
        marginTop="0">
        <box
            width="190"
            height="80"
            align="top"
            marginTop="0">
            <box
                width="162"
                height="60"
                align="left"
                marginTop="0"
                marginLeft="28">
                <textarea
                    width="130"
                    height="60"
                    size="50"
                    name="distanceValue"
                    content="---"
                    text_align="right"
                    color="@color/single_unit_text"/>
                <textarea
                    width="12"
                    height="60"
                    size="12"
                    name="distanceUnits"
                    content="-"
                    marginLeft="8"
                    marginTop="15"/>
            </box>
            <box
                width="190"
                height="20"
                align="top"
                marginTop="0">
                <textarea
                    width="190"
                    height="20"
                    size="16"
                    name="distanceLabel"
                    content="DISTANCE"
                    text_align="center_horizontal"/>
            </box>
        </box>
        <rectangle
            width="1"
            height="80"
            marginLeft="24"
            marginRight="24"
            marginTop="0"
            color="@color/white"/>
        <box
            width="190"
            height="80"
            align="top"
            marginTop="0">
            <box
                width="132"
                height="60"
                align="left"
                marginTop="0"
                marginLeft="28">
                <textarea
                    width="110"
                    height="60"
                    size="50"
                    name="speedValue"
                    content="---"
                    text_align="right"
                    color="@color/single_unit_text"/>
                <textarea
                    width="12"
                    height="60"
                    size="12"
                    name="speedUnits"
                    content="-"
                    marginLeft="8"
                    marginTop="15"/>
            </box>
            <box
                width="190"
                height="20"
                align="top"
                marginTop="0">
                <textarea
                    width="190"
                    height="20"
                    size="16"
                    name="speedLabel"
                    content="AVG. SPEED"
                    text_align="center_horizontal"/>
            </box>
        </box>
    </box>
</page>
