<?xml version="1.0" encoding="utf-8"?>
<page
    name="single_metric"
    align="top"
    version="2">
    <include source="_header"/>
    <box
        name="main"
        width="428"
        height="110"
        align="right"
        marginTop="10"
        paddingRight="14"
        paddingLeft="14">
        <textarea
            width="130"
            height="40"
            size="22"
            name="unit"
            content="---"
            marginLeft="10"
            marginTop="65"
            iosVerticalAdjust="20"/>
        <textarea
            width="260"
            height="110"
            size="92"
            name="value"
            content="-------"
            bold="true"
            text_align="right"
            colour="@color/single_unit_text"/>
