    <textarea
        width="428"
        height="36"
        marginTop="10"
        size="20"
        name="label"
        content="----------------"
        bold="false"
        text_align="center_horizontal"
        iconName="metric_image"
        source="SPEED"
        iconWidth="36"
        iconHeight="36"/>
</page>
