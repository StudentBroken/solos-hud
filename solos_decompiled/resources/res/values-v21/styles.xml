<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ComposerDark" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:textColorSecondary">@color/tw__composer_deep_gray</item>
        <item name="android:textColor">@color/tw__composer_white</item>
        <item name="android:textColorHint">@color/tw__composer_light_gray</item>
        <item name="tw__twitter_logo">@drawable/tw__composer_logo_white</item>
    </style>
    <style name="ComposerLight" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:textColorSecondary">@color/tw__composer_deep_gray</item>
        <item name="android:textColor">@color/tw__composer_black</item>
        <item name="android:textColorHint">@color/tw__composer_light_gray</item>
        <item name="tw__twitter_logo">@drawable/tw__composer_logo_blue</item>
    </style>
    <style name="Digits_default" parent="@android:style/Theme.Material.Light">
        <item name="dgts__accentColor">?android:attr/colorAccent</item>
    </style>
    <style name="MediaTheme" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
    <style name="tw__TweetFullName" parent="@style/tw__TweetFullNameBase">
        <item name="android:importantForAccessibility">2</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppearance.Compat.Notification" parent="@android:style/TextAppearance.Material.Notification">
    </style>
    <style name="TextAppearance.Compat.Notification.Info" parent="@android:style/TextAppearance.Material.Notification.Info">
    </style>
    <style name="TextAppearance.Compat.Notification.Info.Media" parent="@style/TextAppearance.Compat.Notification.Info">
        <item name="android:textColor">@color/secondary_text_default_material_dark</item>
    </style>
    <style name="TextAppearance.Compat.Notification.Media" parent="@style/TextAppearance.Compat.Notification">
        <item name="android:textColor">@color/secondary_text_default_material_dark</item>
    </style>
    <style name="TextAppearance.Compat.Notification.Time" parent="@android:style/TextAppearance.Material.Notification.Time">
    </style>
    <style name="TextAppearance.Compat.Notification.Time.Media" parent="@style/TextAppearance.Compat.Notification.Time">
        <item name="android:textColor">@color/secondary_text_default_material_dark</item>
    </style>
    <style name="TextAppearance.Compat.Notification.Title" parent="@android:style/TextAppearance.Material.Notification.Title">
    </style>
    <style name="TextAppearance.Compat.Notification.Title.Media" parent="@style/TextAppearance.Compat.Notification.Title">
        <item name="android:textColor">@color/primary_text_default_material_dark</item>
    </style>
    <style name="TextAppearance.WearDiag" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/primary_text_dark</item>
    </style>
    <style name="TextAppearance.WearDiag.Button" parent="@style/TextAppearance.WearDiag">
        <item name="android:textSize">16sp</item>
    </style>
    <style name="TextAppearance.WearDiag.Message" parent="@style/TextAppearance.WearDiag">
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingMultiplier">0.96</item>
    </style>
    <style name="TextAppearance.WearDiag.Title" parent="@style/TextAppearance.WearDiag">
        <item name="android:textSize">20sp</item>
        <item name="android:lineSpacingMultiplier">0.9387</item>
    </style>
    <style name="Theme.WearDiag" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:colorBackground">@color/dialog_background</item>
        <item name="android:textAppearance">@style/TextAppearance.WearDiag</item>
        <item name="android:buttonStyle">@style/Widget.WearDiag.Button</item>
        <item name="android:windowBackground">@color/dialog_background</item>
        <item name="android:colorBackgroundCacheHint">@color/dialog_background</item>
    </style>
    <style name="Widget.ActionPage" parent="@android:style/Widget">
        <item name="android:textColor">@color/primary_text_dark</item>
        <item name="android:background">#99000000</item>
        <item name="android:maxLines">2</item>
        <item name="android:color">@color/circular_button</item>
        <item name="android:fontFamily">sans-serif-condensed-light</item>
        <item name="android:elevation">@dimen/circular_button_elevation</item>
        <item name="android:stateListAnimator">@animator/circular_image_button_anim</item>
        <item name="minTextSize">12sp</item>
        <item name="maxTextSize">20sp</item>
        <item name="buttonRippleColor">@color/circular_button_pressed</item>
    </style>
    <style name="Widget.Compat.NotificationActionContainer" parent="">
        <item name="android:background">@drawable/notification_action_background</item>
    </style>
    <style name="Widget.Compat.NotificationActionText" parent="">
        <item name="android:textAppearance">?android:attr/textAppearanceButton</item>
        <item name="android:textSize">@dimen/notification_action_text_size</item>
        <item name="android:textColor">@color/secondary_text_default_material_light</item>
    </style>
    <style name="Widget.WearDiag.Button" parent="@android:style/Widget.DeviceDefault.Button">
        <item name="android:textAppearance">@style/TextAppearance.WearDiag.Button</item>
        <item name="android:ellipsize">4</item>
        <item name="android:gravity">0x13</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:layout_width">-1</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:maxLines">3</item>
        <item name="android:minLines">1</item>
        <item name="android:drawablePadding">12dp</item>
        <item name="android:fontFamily">sans-serif-condensed-light</item>
    </style>
    <style name="Widget.WearDiag.TextView" parent="@android:style/Widget.DeviceDefault.TextView">
        <item name="android:fontFamily">sans-serif-condensed-light</item>
    </style>
    <style name="Widget.WearDiag.TextView.Message" parent="@style/Widget.WearDiag.TextView">
        <item name="android:textAppearance">@style/TextAppearance.WearDiag.Message</item>
        <item name="android:gravity">0x3</item>
    </style>
    <style name="Widget.WearDiag.TextView.Title" parent="@style/Widget.WearDiag.TextView">
        <item name="android:textAppearance">@style/TextAppearance.WearDiag.Title</item>
        <item name="android:gravity">0x11</item>
    </style>
</resources>
