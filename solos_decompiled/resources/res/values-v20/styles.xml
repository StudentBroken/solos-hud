<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CardText" parent="@style/CardTextBase">
    </style>
    <style name="CardTextBase" parent="@style/TextView.Medium.Light">
        <item name="android:textColor">@color/card_text_color</item>
        <item name="android:layout_width">-2</item>
        <item name="android:layout_height">-2</item>
        <item name="android:lineSpacingMultiplier">0.92</item>
    </style>
    <style name="CardTitle" parent="@style/CardTitleBase">
    </style>
    <style name="CardTitleBase" parent="@style/TextView.Medium.Light">
        <item name="android:textColor">@color/card_grey_text_color</item>
        <item name="android:ellipsize">3</item>
        <item name="android:layout_width">-2</item>
        <item name="android:layout_height">-2</item>
        <item name="android:maxLines">2</item>
        <item name="android:singleLine">false</item>
    </style>
    <style name="DismissOverlayText" parent="@style/TextView.Large.Light">
        <item name="android:textColor">@color/primary_text_dark</item>
        <item name="android:gravity">0x11</item>
        <item name="android:background">@color/dismiss_close</item>
        <item name="android:lineSpacingExtra">-2sp</item>
    </style>
    <style name="DotsPageIndicatorStyle" parent="">
        <item name="dotSpacing">7.8dp</item>
        <item name="dotRadius">2.1dp</item>
        <item name="dotRadiusSelected">3.1dp</item>
        <item name="dotColor">@color/white</item>
        <item name="dotColorSelected">@color/white</item>
        <item name="dotFadeWhenIdle">true</item>
        <item name="dotFadeOutDelay">1000</item>
        <item name="dotFadeOutDuration">250</item>
        <item name="dotFadeInDuration">100</item>
        <item name="dotShadowColor">#66000000</item>
        <item name="dotShadowRadius">2px</item>
        <item name="dotShadowDx">1px</item>
        <item name="dotShadowDy">1px</item>
    </style>
    <style name="PageIndicatorViewStyle" parent="">
        <item name="pageIndicatorDotSpacing">7.8dp</item>
        <item name="pageIndicatorDotRadius">2.1dp</item>
        <item name="pageIndicatorDotRadiusSelected">3.1dp</item>
        <item name="pageIndicatorDotColor">?android:attr/colorForeground</item>
        <item name="pageIndicatorDotColorSelected">?android:attr/colorForeground</item>
        <item name="pageIndicatorDotFadeWhenIdle">true</item>
        <item name="pageIndicatorDotFadeOutDelay">1000</item>
        <item name="pageIndicatorDotFadeOutDuration">250</item>
        <item name="pageIndicatorDotFadeInDuration">100</item>
        <item name="pageIndicatorDotShadowColor">#66000000</item>
        <item name="pageIndicatorDotShadowRadius">2px</item>
        <item name="pageIndicatorDotShadowDx">1px</item>
        <item name="pageIndicatorDotShadowDy">1px</item>
    </style>
    <style name="TextAppearance.Wearable.Large" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/primary_text_light</item>
    </style>
    <style name="TextAppearance.Wearable.Medium" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/primary_text_light</item>
    </style>
    <style name="TextAppearance.Wearable.Small" parent="@android:style/TextAppearance.Medium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/primary_text_light</item>
    </style>
    <style name="TextView.Large" parent="@android:style/Widget.Holo.Light">
        <item name="android:textAppearance">@style/TextAppearance.Wearable.Large</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>
    <style name="TextView.Large.Light" parent="@style/TextView.Large">
        <item name="android:textAppearance">@style/TextAppearance.Wearable.Large</item>
        <item name="android:fontFamily">sans-serif-condensed-light</item>
    </style>
    <style name="TextView.Medium" parent="@android:style/Widget.Holo.Light">
        <item name="android:textAppearance">@style/TextAppearance.Wearable.Medium</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>
    <style name="TextView.Medium.Light" parent="@style/TextView.Medium">
        <item name="android:textAppearance">@style/TextAppearance.Wearable.Medium</item>
        <item name="android:fontFamily">sans-serif-condensed-light</item>
    </style>
    <style name="TextView.Small" parent="@android:style/Widget.Holo.Light">
        <item name="android:textAppearance">@style/TextAppearance.Wearable.Small</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>
    <style name="TextView.Small.Light" parent="@style/TextView.Small">
        <item name="android:textAppearance">@style/TextAppearance.Wearable.Small</item>
        <item name="android:fontFamily">sans-serif-condensed-light</item>
    </style>
    <style name="Theme.Wearable" parent="@android:style/Theme.DeviceDefault">
    </style>
    <style name="Theme.Wearable.Modal" parent="@style/Theme.Wearable">
        <item name="android:windowSwipeToDismiss">false</item>
    </style>
</resources>
