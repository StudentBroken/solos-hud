<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/solos_back"
        android:scaleType="fitXY"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/header"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_gravity="center"
            android:paddingTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="70dp"
            android:src="@drawable/ic_solos_logo"
            android:layout_alignParentTop="true"/>
        <TextView
            android:textSize="19sp"
            android:textColor="@color/solos_white"
            android:gravity="center"
            android:layout_gravity="center"
            android:paddingTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/header_re_sign_in"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:id="@+id/layoutPic"
                android:padding="12dp"
                android:visibility="invisible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true">
                <com.kopin.solos.view.RoundedImageView
                    android:id="@+id/imgProfileUser"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/profile_ic"
                    android:minWidth="70dp"
                    android:minHeight="70dp"
                    android:layout_alignParentTop="true"
                    android:layout_centerHorizontal="true"/>
                <ImageView
                    android:id="@+id/imgProfileUserDefault"
                    android:visibility="gone"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/default_image_ic"
                    android:layout_centerHorizontal="true"/>
            </RelativeLayout>
            <LinearLayout
                android:orientation="vertical"
                android:paddingBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:layout_below="@+id/layoutPic"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true">
                <TextView
                    android:textSize="17sp"
                    android:textColor="@color/solos_white"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/txtProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:singleLine="true"/>
                <TextView
                    android:textSize="17sp"
                    android:textColor="#a3a3a3"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/txtEmailName"
                    android:paddingTop="4dp"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:singleLine="true"/>
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/header">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginRight="14dp"
                android:src="@drawable/ic_password"/>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="38dp">
                <EditText
                    android:id="@+id/edPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="@string/peloton_password"
                    android:maxLength="128"
                    android:inputType="textPassword"
                    android:fontFamily="sans-serif"
                    style="@style/SolosLoginPasswordEditText"/>
                <RelativeLayout
                    android:id="@+id/layoutValidPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true">
                    <ImageView
                        android:id="@+id/imgValidPassword"
                        android:visibility="gone"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginRight="4dp"
                        android:src="@drawable/ic_error_login"
                        android:maxLength="128"/>
                </RelativeLayout>
                <TextView
                    android:gravity="center"
                    android:id="@+id/txtShowPassword"
                    android:padding="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="@string/show_password"
                    android:layout_toLeftOf="@+id/layoutValidPassword"
                    android:layout_centerVertical="true"
                    style="@style/SolosLoginSmallTextGrey"/>
            </RelativeLayout>
        </LinearLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="@string/peloton_login"
                style="@style/SolosLoginButton"/>
            <ProgressBar
                android:id="@+id/progressBar"
                android:padding="4dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <TextView
            android:gravity="center"
            android:autoLink="all"
            android:linksClickable="false"
            android:id="@+id/textForgotPwd"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/forgot_password"
            android:selectAllOnFocus="false"
            android:onClick="showForgotPasswordPage"
            style="@style/SolosLoginSmallText"/>
        <TextView
            android:gravity="center"
            android:layout_gravity="center"
            android:paddingTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sign_in_terms"
            style="@style/SolosLoginSmallText"/>
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:autoLink="all"
                android:linksClickable="false"
                android:padding="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/privacy_policy"
                android:selectAllOnFocus="false"
                android:onClick="showPrivacyPage"
                style="@style/SolosLoginSmallText"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/and"
                style="@style/SolosLoginSmallText"/>
            <TextView
                android:autoLink="all"
                android:linksClickable="false"
                android:padding="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/terms"
                android:selectAllOnFocus="false"
                android:onClick="showTermsPage"
                style="@style/SolosLoginSmallText"/>
        </LinearLayout>
        <TextView
            android:textColor="@color/solos_white"
            android:gravity="center"
            android:id="@+id/txtResponse"
            android:padding="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <TextView
            android:textColor="@color/solos_white"
            android:gravity="center"
            android:autoLink="all"
            android:linksClickable="false"
            android:layout_gravity="center"
            android:id="@+id/txtNewAccount"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sign_in_different_account"
            android:selectAllOnFocus="false"/>
    </LinearLayout>
</RelativeLayout>
