<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:layout_above="@+id/btnBar">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/pref_background"
                android:padding="1dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp">
                <LinearLayout
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:id="@+id/layoutTitleInput"
                    android:background="@drawable/finish_ride_row_template"
                    android:padding="@dimen/layout_padding"
                    android:clickable="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:onClick="onViewClick">
                    <TextView
                        android:id="@+id/textView3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/finish_ride_name"
                        android:layout_weight="1"
                        style="@style/EndRideTitleText"/>
                    <TextView
                        android:id="@+id/txtRideTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/EndRideDetailText"/>
                </LinearLayout>
                <View
                    android:id="@+id/divider1"
                    android:background="@color/about_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"/>
                <LinearLayout
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:id="@+id/layoutSportInput"
                    android:background="@drawable/finish_ride_row_template"
                    android:padding="@dimen/layout_padding"
                    android:clickable="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:onClick="onViewClick">
                    <TextView
                        android:id="@+id/textView5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/finish_ride_activity"
                        android:layout_weight="1"
                        style="@style/EndRideTitleText"/>
                    <TextView
                        android:id="@+id/txtSport"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/EndRideDetailText"/>
                </LinearLayout>
                <View
                    android:id="@+id/divider2"
                    android:background="@color/about_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"/>
                <LinearLayout
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:id="@+id/layoutBikeInput"
                    android:background="@drawable/finish_ride_row_template"
                    android:padding="@dimen/layout_padding"
                    android:clickable="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/textView6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/finish_ride_bike_type"
                        android:layout_weight="1"
                        style="@style/EndRideTitleText"/>
                    <TextView
                        android:id="@+id/txtBike"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/EndRideDetailText"/>
                </LinearLayout>
                <View
                    android:background="@color/about_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"/>
                <LinearLayout
                    android:layout_gravity="center_horizontal"
                    android:orientation="vertical"
                    android:id="@+id/layoutDescInput"
                    android:background="@drawable/finish_ride_row_template"
                    android:padding="@dimen/layout_padding"
                    android:clickable="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:onClick="onViewClick">
                    <TextView
                        android:id="@+id/textView4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/finish_ride_description"
                        android:layout_weight="1"
                        style="@style/EndRideTitleText"/>
                    <TextView
                        android:id="@+id/txtDescr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:lines="2"
                        android:maxEms="80"
                        style="@style/EndRideDetailText"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:textSize="18sp"
                android:id="@+id/textSubTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:text="?attr/strWorkoutSummary"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:id="@+id/txtDistance"
                    android:paddingLeft="30dp"
                    android:paddingRight="30dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:maxLines="1"
                    android:drawableLeft="@drawable/ic_ic_distance_icon"
                    android:drawablePadding="12dp"
                    android:layout_weight="1"/>
                <TextView
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:id="@+id/txtDuration"
                    android:paddingLeft="30dp"
                    android:paddingRight="30dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:maxLines="1"
                    android:drawableLeft="@drawable/ic_target_time_icon2"
                    android:drawablePadding="12dp"
                    android:layout_weight="1"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="6dp">
                <TextView
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:id="@+id/txtMetric3"
                    android:paddingLeft="30dp"
                    android:paddingRight="30dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="@string/elevation_not_applicable"
                    android:maxLines="1"
                    android:drawableLeft="@drawable/ic_elevation"
                    android:drawablePadding="12dp"
                    android:layout_weight="1"/>
                <TextView
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:id="@+id/txtMetric4"
                    android:paddingLeft="30dp"
                    android:paddingRight="30dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:maxLines="1"
                    android:drawableLeft="@drawable/ic_ic_speed_icon"
                    android:drawablePadding="12dp"
                    android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/btnBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <TextView
            android:gravity="center"
            android:id="@+id/textShare"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:text="?attr/strShareWorkoutMessage"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/layoutShare"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="30dp"
            android:layout_marginTop="6dp"
            android:layout_marginRight="30dp">
            <ImageView
                android:id="@+id/imgFacebook"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/facebook_new_ic"
                android:onClick="onViewClick"/>
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            <ImageView
                android:id="@+id/imgTrainingPeaks"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/tp_xhdpi"
                android:onClick="onViewClick"/>
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            <ImageView
                android:id="@+id/imgTwitter"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/twitter_xhdpi"
                android:onClick="onViewClick"/>
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            <ImageView
                android:id="@+id/imgStrava"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/strava_xhdpi"
                android:onClick="onViewClick"/>
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            <ImageView
                android:id="@+id/imgMapMyRide"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/mmr_xhdpi"
                android:onClick="onViewClick"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="18dp">
            <com.kopin.solos.view.SafeButton
                android:textColor="@android:color/white"
                android:layout_gravity="center_horizontal"
                android:id="@+id/btnSaveRide"
                android:background="@drawable/borderless_button_gray"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginRight="6dp"
                android:text="?attr/strSaveWorkout"
                android:layout_weight="1"
                style="?android:attr/borderlessButtonStyle"/>
            <Button
                android:textColor="@android:color/white"
                android:layout_gravity="center_horizontal"
                android:id="@+id/btnDiscardRide"
                android:background="@drawable/borderless_button_red"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="6dp"
                android:text="@string/discard_ride"
                android:layout_weight="1"
                android:onClick="onViewClick"
                style="?android:attr/borderlessButtonStyle"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
