<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/card_container"
    android:background="@color/element_background_light1"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:focusable="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center_vertical"
            android:id="@+id/card_back"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:textAppearance="?android:attr/textAppearanceLarge"
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/remove_route"
                android:layout_weight="2"/>
            <ImageButton
                android:id="@+id/btnDeleteRide"
                android:background="@android:color/transparent"
                android:visibility="invisible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_delete"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/card_front"
            android:layout_width="match_parent"
            android:layout_height="110dp">
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/manage_route_background"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <Space
                    android:layout_width="10dp"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/ic_saved_routes"
                    android:tint="@color/navigation_white"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0px"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:textColor="@color/navigation_white"
                        android:gravity="center"
                        android:id="@+id/route_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/navigation_search_padding"
                        android:maxLines="1"
                        android:lines="1"
                        style="@style/manage_route_main"/>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textColor="@color/navigation_white"
                            android:gravity="center"
                            android:id="@+id/route_distance"
                            android:padding="5dp"
                            android:layout_width="0px"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/manage_route_large"/>
                        <Space
                            android:layout_width="@dimen/manage_route_padding"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:textColor="@color/navigation_white"
                            android:gravity="center"
                            android:id="@+id/route_distance_unit"
                            android:padding="5dp"
                            android:layout_width="0px"
                            android:layout_height="wrap_content"
                            android:text="METRES"
                            android:layout_weight="1"
                            style="@style/manage_route_small"/>
                    </LinearLayout>
                </LinearLayout>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/card_chevron"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_side_chevron"
                    android:scaleType="centerInside"
                    android:tint="@color/element_background_dark1"
                    android:layout_weight="0"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:background="@color/navigation_orange"
        android:layout_width="match_parent"
        android:layout_height="@dimen/manage_route_spacer"/>
</LinearLayout>
