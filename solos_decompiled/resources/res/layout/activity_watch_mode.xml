<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:id="@+id/activity_watch_mode"
    android:background="@drawable/solos_back"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="#9d000000"
    android:backgroundTintMode="src_atop">
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="30dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_gravity="center_horizontal"
            android:id="@+id/imageView"
            android:layout_width="40dp"
            android:layout_height="80dp"
            android:layout_marginBottom="20dp"
            android:src="@drawable/ic_watch_spin"/>
        <TextView
            android:gravity="center_horizontal"
            android:id="@+id/textHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RIDE IN PROGRESS"
            android:drawablePadding="10dp"
            android:textAllCaps="true"/>
        <TextView
            android:gravity="center_horizontal"
            android:id="@+id/textMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/share_please_wait"/>
        <Button
            android:textColor="@color/white"
            android:id="@+id/btnOK"
            android:background="@drawable/rounded_corner_button"
            android:visibility="gone"
            android:layout_width="100dp"
            android:layout_height="40dp"
            android:layout_marginTop="60dp"
            android:text="@string/dialog_button_ok"
            android:onClick="onOkClick"/>
    </LinearLayout>
</LinearLayout>
