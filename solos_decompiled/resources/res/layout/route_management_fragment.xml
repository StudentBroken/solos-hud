<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="?attr/drawableAppBg"
        android:scaleType="centerCrop"/>
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/transparent"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/directions_search_box"
            android:padding="@dimen/navigation_search_padding"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/navigation_search_box_height">
            <ImageView
                android:id="@+id/directions_search_icon"
                android:visibility="visible"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_search_black_24dp"
                android:tint="@color/navigation_white"
                android:layout_weight="1"/>
            <EditText
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:textColor="@color/black"
                android:id="@+id/navigate_text_box"
                android:background="@color/transparent"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:hint="@string/navigate_search_route"
                android:layout_weight="8"
                android:textCursorDrawable="@null"/>
            <ImageView
                android:id="@+id/directions_clear_icon"
                android:visibility="invisible"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_clear_black_24dp"
                android:tint="@color/navigation_white"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/directions_results"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/directions_no_routes"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="0px"
            android:layout_weight="1">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_no_saved_routes"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="0px"
            android:layout_weight="1">
            <TextView
                android:gravity="center"
                android:paddingLeft="@dimen/navigation_no_routes_padding"
                android:paddingRight="@dimen/navigation_no_routes_padding"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/navigate_no_route_1"
                style="@style/no_route_large"/>
            <Space
                android:layout_width="match_parent"
                android:layout_height="@dimen/navigation_no_routes_space"/>
            <TextView
                android:gravity="center"
                android:paddingLeft="@dimen/navigation_no_routes_padding"
                android:paddingRight="@dimen/navigation_no_routes_padding"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="?attr/strNoRoutesMessage3"
                style="@style/no_route_main"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/directions_confirm_layout"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <include layout="@layout/directions_confirmation_route"/>
    </LinearLayout>
</RelativeLayout>
