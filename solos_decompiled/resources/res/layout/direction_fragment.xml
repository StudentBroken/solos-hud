<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <fragment
        android:name="com.google.android.gms.maps.MapFragment"
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/directions_search_box"
        android:background="@color/transparent"
        android:padding="@dimen/navigation_search_padding"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:background="@drawable/navigate_search_background"
            android:padding="@dimen/navigation_search_padding"
            android:layout_width="match_parent"
            android:layout_height="@dimen/navigation_search_box_height">
            <ImageView
                android:id="@+id/directions_search_icon"
                android:visibility="visible"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_search_black_24dp"
                android:layout_weight="1"/>
            <EditText
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:textColor="@color/black"
                android:id="@+id/navigate_text_box"
                android:background="@color/transparent"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:hint="@string/navigate_search_address"
                android:layout_weight="8"
                android:textCursorDrawable="@null"/>
            <ImageView
                android:id="@+id/directions_clear_icon"
                android:visibility="invisible"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_clear_black_24dp"
                android:layout_weight="1"/>
        </LinearLayout>
        <Space
            android:background="@color/transparent"
            android:layout_width="match_parent"
            android:layout_height="@dimen/navigation_search_padding"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/directions_results"
            android:background="@drawable/navigate_search_background"
            android:padding="@dimen/navigation_search_padding"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ListView
                android:id="@+id/places_list_view"
                android:background="@color/transparent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:listSelector="@color/navigation_transparent_orange"
                android:drawSelectorOnTop="true"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/directions_no_internet"
        android:background="@color/lap_list_background"
        android:padding="@dimen/navigation_search_padding"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:layout_gravity="center_horizontal"
            android:id="@+id/imageStrava"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="75dp"
            android:src="@drawable/ic_no_internet"/>
        <TextView
            android:gravity="center"
            android:padding="@dimen/navigation_search_padding"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/text_no_internet_strava"
            style="@style/no_internet_style"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/directions_confirm_layout"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <include layout="@layout/directions_confirmation"/>
    </LinearLayout>
</RelativeLayout>
