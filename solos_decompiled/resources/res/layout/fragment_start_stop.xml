<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="?attr/drawableAppBg"
        android:scaleType="centerCrop"/>
    <TextView
        android:gravity="center_horizontal"
        android:id="@+id/txtHeadsetState"
        android:background="#00707070"
        android:padding="3dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <TextView
        android:gravity="center_horizontal"
        android:id="@+id/textGroupcomStatus"
        android:background="#00707070"
        android:padding="3dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CONNECTED  |  GEARS FOR BEARS |  00:00:18"
        android:maxLines="1"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="30dp">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.25">
            <LinearLayout
                android:layout_gravity="center"
                android:orientation="vertical"
                android:id="@+id/layoutTimerNormal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/start_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_default_timer_time"
                    style="@style/TimerText"/>
                <TextView
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/txtTimerCaption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/elapsed_time"
                    style="@style/RecordCaptionText"/>
            </LinearLayout>
            <LinearLayout
                android:layout_gravity="center"
                android:orientation="vertical"
                android:id="@+id/layoutTimerFTP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView
                        android:ellipsize="end"
                        android:id="@+id/txtDurationValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txtDurationValueFTP"
                        android:maxLines="1"
                        android:singleLine="true"
                        style="@style/TimerText"/>
                </LinearLayout>
                <TextView
                    android:ellipsize="end"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/time_remaining"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:drawableLeft="@drawable/ic_duration"
                    style="@style/RecordCaptionTextSmall"/>
            </LinearLayout>
        </FrameLayout>
        <include layout="@layout/layout_record_screen_divider"/>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.75">
            <LinearLayout
                android:layout_gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@+id/layoutNormalMode"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="0.15">
                    <ImageView
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:id="@+id/pager1LeftEar"
                        android:paddingLeft="14dp"
                        android:paddingTop="24dp"
                        android:paddingRight="14dp"
                        android:paddingBottom="24dp"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_left_chevron_small"
                        android:alpha="0.9"/>
                    <com.kopin.solos.view.PagerContainer
                        android:id="@+id/pager_container1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <android.support.v4.view.ViewPager
                            android:layout_gravity="center_horizontal"
                            android:layout_width="180dp"
                            android:layout_height="90dp"
                            android:minHeight="80dp"
                            android:layout_centerHorizontal="true"/>
                    </com.kopin.solos.view.PagerContainer>
                    <ImageView
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:id="@+id/pager1RightEar"
                        android:paddingLeft="14dp"
                        android:paddingTop="24dp"
                        android:paddingRight="14dp"
                        android:paddingBottom="24dp"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_right_chevron_small"
                        android:alpha="0.9"/>
                </LinearLayout>
                <include layout="@layout/layout_record_screen_divider"/>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="0.15">
                    <ImageView
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:id="@+id/pager2LeftEar"
                        android:paddingLeft="14dp"
                        android:paddingTop="24dp"
                        android:paddingRight="14dp"
                        android:paddingBottom="24dp"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_left_chevron_small"
                        android:alpha="0.9"/>
                    <com.kopin.solos.view.PagerContainer
                        android:id="@+id/pager_container2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <android.support.v4.view.ViewPager
                            android:layout_gravity="center_horizontal"
                            android:layout_width="180dp"
                            android:layout_height="90dp"
                            android:minHeight="80dp"
                            android:layout_centerHorizontal="true"/>
                    </com.kopin.solos.view.PagerContainer>
                    <ImageView
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:id="@+id/pager2RightEar"
                        android:paddingLeft="14dp"
                        android:paddingTop="24dp"
                        android:paddingRight="14dp"
                        android:paddingBottom="24dp"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_right_chevron_small"
                        android:alpha="0.9"/>
                </LinearLayout>
                <include layout="@layout/layout_record_screen_divider"/>
                <RelativeLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="0.15">
                    <ImageView
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:id="@+id/pager3LeftEar"
                        android:paddingLeft="14dp"
                        android:paddingTop="24dp"
                        android:paddingRight="14dp"
                        android:paddingBottom="24dp"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_left_chevron_small"
                        android:layout_alignParentLeft="true"
                        android:layout_centerVertical="true"
                        android:alpha="0.9"/>
                    <com.kopin.solos.view.PagerContainer
                        android:id="@+id/pager_container3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <android.support.v4.view.ViewPager
                            android:layout_gravity="center_horizontal"
                            android:layout_width="180dp"
                            android:layout_height="90dp"
                            android:layout_centerHorizontal="true"/>
                    </com.kopin.solos.view.PagerContainer>
                    <ImageView
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:id="@+id/pager3RightEar"
                        android:paddingLeft="14dp"
                        android:paddingTop="24dp"
                        android:paddingRight="14dp"
                        android:paddingBottom="24dp"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_right_chevron_small"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:alpha="0.9"/>
                </RelativeLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@+id/layoutFTPMode"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView
                        android:ellipsize="end"
                        android:id="@+id/txtPowerValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/placeholder_int"
                        android:maxLines="1"
                        android:singleLine="true"
                        style="@style/FTPRecordMetricText"/>
                    <TextView
                        android:ellipsize="end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:text="@string/power_unit_abbrev"
                        android:maxLines="1"
                        android:singleLine="true"
                        style="@style/RecordUnitText"/>
                </LinearLayout>
                <TextView
                    android:ellipsize="end"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/vc_title_power"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:drawableLeft="?attr/iconFtpPower"
                    style="@style/RecordCaptionTextSmall"/>
                <include layout="@layout/layout_record_screen_divider"/>
                <LinearLayout
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView
                        android:ellipsize="end"
                        android:id="@+id/txtAvePowerValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/placeholder_int"
                        android:maxLines="1"
                        android:singleLine="true"
                        style="@style/FTPRecordMetricText"/>
                    <TextView
                        android:ellipsize="end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:text="@string/power_unit_abbrev"
                        android:maxLines="1"
                        android:singleLine="true"
                        style="@style/RecordUnitText"/>
                </LinearLayout>
                <TextView
                    android:ellipsize="end"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/txtMetricCaption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/vc_title_average_power"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:drawableLeft="?attr/iconFtpPower"
                    style="@style/RecordCaptionTextSmall"/>
                <Button
                    android:textSize="26sp"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/btnCancel"
                    android:background="@drawable/borderless_button_red"
                    android:layout_width="170dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="60dp"
                    android:text="@string/cancel"
                    android:textAllCaps="true"
                    android:fontFamily="sans-serif-condensed"
                    style="?android:attr/borderlessButtonStyle"/>
            </LinearLayout>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/btnBar"
            android:layout_width="match_parent"
            android:layout_height="60dp">
            <LinearLayout
                android:gravity="center_horizontal"
                android:id="@+id/btnBar2"
                android:background="@color/ride_pref_background"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:requiresFadingEdge="vertical">
                <Button
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:id="@+id/btnPause"
                    android:paddingTop="16dp"
                    android:paddingBottom="4dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:drawableTop="@drawable/ic_pause"
                    android:layout_weight="1"
                    style="@android:style/Widget.Holo.Button.Borderless"/>
                <ImageButton
                    android:layout_gravity="center_vertical"
                    android:id="@+id/btnLock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_lock_ride"
                    android:hapticFeedbackEnabled="false"
                    style="@android:style/Widget.Holo.Button.Borderless"/>
                <Button
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:id="@+id/btnStop"
                    android:paddingTop="16dp"
                    android:paddingBottom="4dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/caption_finish"
                    android:drawableTop="@drawable/ic_finish"
                    android:layout_weight="1"
                    style="@android:style/Widget.Holo.Button.Borderless"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="horizontal"
                android:id="@+id/btnBar1"
                android:background="@color/ride_pref_background"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:requiresFadingEdge="horizontal">
                <Button
                    android:id="@+id/btnBikeType"
                    android:layout_width="290dp"
                    android:layout_height="match_parent"
                    android:text="@string/finish_ride_bike_type_msg"
                    android:drawableTop="@drawable/ic_bike"
                    android:layout_weight="1"
                    android:paddingStart="10dp"
                    style="@style/RecordScreenButton"/>
                <Button
                    android:textSize="26sp"
                    android:id="@+id/btnRecord"
                    android:background="@drawable/background_record_btn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:textAllCaps="true"
                    android:fontFamily="sans-serif-condensed"/>
                <Button
                    android:id="@+id/btnQuickSettings"
                    android:layout_width="290dp"
                    android:layout_height="match_parent"
                    android:text="@string/quick_settings"
                    android:drawableTop="@drawable/ic_quick_settings"
                    android:layout_weight="1"
                    android:onClick="showQuickSettings"
                    android:paddingStart="10dp"
                    style="@style/RecordScreenButton"/>
            </LinearLayout>
            <View
                android:id="@+id/shadowOverlay"
                android:clickable="false"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </FrameLayout>
    </LinearLayout>
</RelativeLayout>
