<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="190dp">
    <RelativeLayout
        android:orientation="vertical"
        android:id="@+id/rlGraph"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="190dp">
        <ImageView
            android:id="@+id/graph_image"
            android:layout_width="@dimen/preview_graph_width"
            android:layout_height="@dimen/preview_graph_height"
            android:layout_centerInParent="true"/>
        <ImageView
            android:id="@+id/graph_extra_data"
            android:layout_width="@dimen/preview_graph_extra_data_width"
            android:layout_height="@dimen/preview_graph_height"
            android:layout_toRightOf="@+id/graph_image"
            android:layout_centerInParent="true"/>
        <ImageView
            android:id="@+id/graph_labels_x"
            android:layout_width="@dimen/preview_graph_width"
            android:layout_height="@dimen/preview_graph_labels_x_height"
            android:layout_below="@+id/graph_image"
            android:layout_alignLeft="@+id/graph_image"/>
        <TextView
            android:textSize="@dimen/preview_label_text_size"
            android:gravity="center"
            android:id="@+id/graph_unit_x"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/txt_graph_time"
            android:layout_below="@+id/graph_labels_x"
            android:layout_centerInParent="true"/>
        <ImageView
            android:id="@+id/graph_labels_y"
            android:layout_width="@dimen/preview_graph_label_y_width"
            android:layout_height="@dimen/preview_graph_height"
            android:layout_toLeftOf="@+id/graph_image"
            android:layout_centerInParent="true"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toStartOf="@+id/graph_labels_y"
            android:layout_alignParentStart="true">
            <com.kopin.solos.view.VerticalTextView
                android:textSize="@dimen/preview_label_text_size"
                android:gravity="bottom"
                android:id="@+id/graph_unit_y"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_graph_speed"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
    </RelativeLayout>
    <TextView
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:gravity="center"
        android:id="@+id/textOverlay"
        android:layout_width="wrap_content"
        android:layout_height="190dp"
        android:text="@string/loading_graph"
        android:layout_centerHorizontal="true"
        android:layout_centerVertical="true"
        style="@style/PreviewMediumText"/>
</RelativeLayout>
