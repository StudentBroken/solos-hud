<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/lister_top_bar"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/pref_background"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:gravity="center_vertical"
            android:id="@+id/txtDeviceTitle"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/setup_profile_item_height"
            android:layout_marginLeft="@dimen/setup_left_margin"
            android:text="@string/searching"
            style="@style/EndRideTitleText"/>
        <include layout="@layout/view_setup_divider"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="@dimen/setup_profile_item_height"
            android:layout_marginLeft="@dimen/setup_left_margin">
            <TextView
                android:textColor="@android:color/white"
                android:id="@+id/txtDeviceStatus"
                android:visibility="visible"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/try_again"
                android:layout_weight="1"
                style="@style/EndRideTitleText"/>
            <ProgressBar
                android:id="@+id/progressSpinner"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginRight="10dp"
                android:indeterminate="true"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/btnBar"
            android:background="@drawable/btn_bar_top_border"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:weightSum="2">
            <Button
                android:textColor="@drawable/toggle_button"
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Back"
                android:layout_weight="1"
                style="?android:attr/borderlessButtonStyle"/>
            <View
                android:id="@+id/ViewColorPickerHelper"
                android:background="@color/prefs_listview_divider"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_margin="5dp"/>
            <Button
                android:textColor="@drawable/toggle_button"
                android:id="@+id/btnRetry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Retry"
                android:layout_weight="1"
                style="?android:attr/borderlessButtonStyle"/>
        </LinearLayout>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/layoutStepMsg"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:layout_marginLeft="36dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="34dp">
        <ImageView
            android:id="@+id/imgHeart"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="2dp"
            android:layout_marginRight="12dp"
            android:src="@drawable/ic_info"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"/>
        <TextView
            android:layout_gravity="center"
            android:id="@+id/txtStepMsg"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="@string/msg_headset_instruction"
            android:layout_toRightOf="@+id/imgHeart"
            android:layout_alignParentTop="true"
            style="@style/SetupTextMessage"/>
    </RelativeLayout>
</LinearLayout>
