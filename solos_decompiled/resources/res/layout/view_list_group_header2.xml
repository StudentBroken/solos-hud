<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textColor="@color/solos_orange"
        android:id="@+id/txtGroupTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Thursday"
        android:layout_weight="1"
        android:textAllCaps="true"
        android:layout_marginStart="25dp"/>
    <TextView
        android:gravity="end|center_vertical"
        android:id="@+id/txtGroupSubTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="14 June"/>
    <ImageView
        android:id="@+id/imageChevron"
        android:padding="5dp"
        android:visibility="invisible"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:src="@drawable/ic_side_chevron"
        android:tint="@color/solos_orange"
        android:layout_marginStart="10dp"/>
</LinearLayout>
