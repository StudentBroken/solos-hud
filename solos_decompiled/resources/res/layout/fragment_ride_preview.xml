<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textSize="18sp"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/txtLaps"
        android:padding="4dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/laps_all"
        android:drawableRight="@drawable/background_spinner_btn"/>
    <ScrollView
        android:id="@+id/preview_scroll_view"
        android:scrollbars="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_below="@+id/txtLaps">
        <com.kopin.solos.views.MetricsListView
            android:orientation="vertical"
            android:id="@+id/cards_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.kopin.solos.view.ExpandableCardView
                android:id="@+id/preview_card_time_distance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.kopin.solos.views.MetricsListView>
    </ScrollView>
    <RelativeLayout
        android:id="@+id/listLapsLayout"
        android:background="#77000000"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/txtLaps">
        <ListView
            android:id="@+id/listLaps"
            android:background="@color/lap_list_background"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:listSelector="@drawable/item_background_highlight"
            android:layout_alignParentTop="true"
            android:layout_centerHorizontal="true"/>
    </RelativeLayout>
    <include
        android:id="@+id/syncBar"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        layout="@layout/view_sync_bar"/>
    <TextView
        android:textColor="@color/sync_bar_offline_text"
        android:gravity="center_horizontal"
        android:id="@+id/txtWarning"
        android:background="@color/sync_bar_background"
        android:padding="3dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"/>
</RelativeLayout>
