<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/hr_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:weightSum="60"
        android:layout_below="@+id/graph_image">
        <TextView
            android:textSize="@dimen/hrzone_graph_label_text_size"
            android:gravity="center"
            android:id="@+id/txtTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/caps_heart_rate_zone"
            android:layout_weight="40"/>
        <TextView
            android:textSize="@dimen/hrzone_graph_label_text_size"
            android:gravity="center"
            android:id="@+id/txtTitleData"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/txt_heartzone_graph_bpm"
            android:layout_weight="20"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/hr_zone_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:weightSum="60"
        android:layout_below="@+id/hr_header">
        <LinearLayout
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="20">
            <View
                android:background="@color/hr_zone1_color"
                android:layout_width="25px"
                android:layout_height="25px"/>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/hrzone_graph_label_text_size"
            android:gravity="left"
            android:id="@+id/txtZoneName1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/hr_zone1_name"
            android:layout_weight="20"/>
        <LinearLayout
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="20">
            <TextView
                android:textSize="@dimen/hrzone_graph_label_text_size"
                android:gravity="center"
                android:id="@+id/hr_zone1_bpm_min"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_zero"/>
            <TextView
                android:textSize="@dimen/hrzone_graph_label_text_size"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_dash"/>
            <TextView
                android:textSize="@dimen/hrzone_graph_label_text_size"
                android:gravity="center"
                android:id="@+id/hr_zone1_bpm_max"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_zero"/>
        </LinearLayout>
    </LinearLayout>
