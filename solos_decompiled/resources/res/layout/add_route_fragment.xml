<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="?attr/drawableAppBg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/navigation_transparent_black"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/pref_background"
                android:padding="1dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <LinearLayout
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:id="@+id/layoutTitleInput"
                    android:background="@drawable/finish_ride_row_template"
                    android:padding="18dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/textView3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/finish_ride_name"
                        android:layout_weight="1"
                        style="@style/EndRideTitleText"/>
                    <TextView
                        android:id="@+id/txtRideTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/EndRideDetailText"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <Space
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/navigation_search_padding"/>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:gravity="center"
                        android:id="@+id/directions_time_header"
                        android:layout_width="0px"
                        android:layout_height="wrap_content"
                        android:text="@string/navigate_time_to_beat"
                        android:layout_weight="1.2"
                        style="@style/add_route_header"/>
                    <TextView
                        android:gravity="center"
                        android:id="@+id/directions_distance_header"
                        android:layout_width="0px"
                        android:layout_height="wrap_content"
                        android:text="@string/distance"
                        android:layout_weight="1"
                        style="@style/add_route_header"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:gravity="center"
                        android:paddingLeft="@dimen/navigation_search_results_padding"
                        android:layout_width="0px"
                        android:layout_height="match_parent"
                        android:layout_weight="1.2">
                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_eta"
                            android:tint="@color/navigation_orange"/>
                        <Space
                            android:layout_width="@dimen/navigation_search_padding"
                            android:layout_height="match_parent"/>
                        <TextView
                            android:gravity="center_vertical"
                            android:id="@+id/directions_total_time"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="00:00:00"
                            style="@style/add_route_small"/>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center"
                        android:layout_width="0px"
                        android:layout_height="match_parent"
                        android:layout_weight="1">
                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginRight="4dp"
                            android:src="@drawable/ic_distance_nav"
                            android:tint="@color/navigation_orange"/>
                        <RelativeLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <TextView
                                android:ellipsize="none"
                                android:gravity="bottom"
                                android:id="@+id/directions_distance_unit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:maxLines="1"
                                android:singleLine="true"
                                android:layout_alignBottom="@+id/directions_total_distance"
                                android:layout_marginEnd="8dp"
                                android:layout_alignParentEnd="true"
                                style="@style/text_metric"/>
                            <TextView
                                android:ellipsize="end"
                                android:gravity="end"
                                android:id="@+id/directions_total_distance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00.00"
                                android:maxLines="1"
                                android:singleLine="true"
                                android:layout_toStartOf="@+id/directions_distance_unit"
                                android:layout_alignParentStart="true"
                                style="@style/add_route_small"/>
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:padding="@dimen/navigation_search_results_padding"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <fragment
                android:name="com.google.android.gms.maps.MapFragment"
                android:id="@+id/map"
                android:layout_width="match_parent"
                android:layout_height="0px"
                android:layout_weight="1"/>
            <Space
                android:layout_width="match_parent"
                android:layout_height="@dimen/navigation_search_padding"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="50dp">
                <Button
                    android:id="@+id/route_save_route"
                    android:background="@drawable/navigate_button_orange"
                    android:layout_width="0px"
                    android:layout_height="match_parent"
                    android:text="@string/navigate_save_route"
                    android:layout_weight="1"
                    style="@style/search_button_text"/>
                <Space
                    android:layout_width="0px"
                    android:layout_height="match_parent"
                    android:layout_weight="0.3"/>
                <Button
                    android:id="@+id/route_cancel"
                    android:background="@drawable/navigate_button_dark_grey"
                    android:layout_width="0px"
                    android:layout_height="match_parent"
                    android:text="@string/navigate_cancel"
                    android:layout_weight="1"
                    style="@style/search_button_text"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
