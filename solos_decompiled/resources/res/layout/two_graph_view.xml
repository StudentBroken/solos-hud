<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:id="@+id/marker"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"/>
    <Button
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/tg_tab_dark_text"
        android:id="@+id/cmdShowFirstGraph"
        android:background="@drawable/border_button_dark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/vc_title_average_heartrate"
        android:layout_toLeftOf="@+id/marker"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"/>
    <Button
        android:textSize="15sp"
        android:textColor="@color/tg_tab_dark_text"
        android:id="@+id/cmdShowSecondGraph"
        android:background="@drawable/border_button_dark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/heart_rate_zones"
        android:layout_toRightOf="@+id/marker"
        android:layout_toEndOf="@+id/cmdShowFirstGraph"
        android:layout_alignParentEnd="true"/>
    <ImageView
        android:id="@+id/imgFirstScreen"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:src="@drawable/arrow_down"
        android:layout_below="@+id/cmdShowFirstGraph"
        android:layout_alignLeft="@+id/cmdShowFirstGraph"
        android:layout_alignRight="@+id/cmdShowFirstGraph"/>
    <ImageView
        android:id="@+id/imgSecondScreen"
        android:visibility="invisible"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:src="@drawable/arrow_down"
        android:layout_below="@+id/cmdShowSecondGraph"
        android:layout_alignLeft="@+id/cmdShowSecondGraph"
        android:layout_alignRight="@+id/cmdShowSecondGraph"/>
    <ViewSwitcher
        android:id="@+id/viewSwitcher"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/imgFirstScreen"/>
</RelativeLayout>
