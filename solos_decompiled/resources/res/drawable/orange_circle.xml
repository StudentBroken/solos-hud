<?xml version="1.0" encoding="utf-8"?>
<rotate xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="1"
    android:fromDegrees="0"
    android:toDegrees="360"
    android:pivotX="50%"
    android:pivotY="50%">
    <shape
        android:shape="ring"
        android:innerRadiusRatio="2.2"
        android:useLevel="false"
        android:thickness="4dp">
        <gradient
            android:startColor="@color/solos_orange"
            android:endColor="@color/text_detail"
            android:useLevel="false"
            android:angle="0"
            android:type="sweep"
            android:centerColor="@color/solos_orange"/>
    </shape>
</rotate>
