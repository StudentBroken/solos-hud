<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CardText" parent="@style/CardTextBase">
        <item name="android:breakStrategy">2</item>
        <item name="android:hyphenationFrequency">1</item>
    </style>
    <style name="CardTitle" parent="@style/CardTitleBase">
        <item name="android:breakStrategy">2</item>
        <item name="android:hyphenationFrequency">1</item>
    </style>
    <style name="CardView" parent="@style/Base.CardView">
        <item name="cardBackgroundColor">?android:attr/colorBackgroundFloating</item>
    </style>
    <style name="WearableActionDrawerItemText" parent="">
        <item name="android:textSize">@dimen/action_drawer_item_text_size</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:ellipsize">3</item>
        <item name="android:layout_gravity">0x10</item>
        <item name="android:maxLines">3</item>
        <item name="android:fontFamily">sans-serif-condensed-light</item>
    </style>
    <style name="WearableActionDrawerTitleText" parent="@android:style/TextAppearance.Material.Subhead">
        <item name="android:alpha">0.7</item>
    </style>
    <style name="WearableWatchFaceSettings" parent="@android:style/Theme.DeviceDefault.Dialog.Alert">
    </style>
</resources>
